{
  "name": "@fairtrail/cli",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "fairtrail-tui": "./dist/index.js"
  },
  "scripts": {
    "dev": "doppler run -- node --import tsx/esm --import ./register.mjs src/index.tsx",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "doppler run -- node --import tsx/esm --import ./register.mjs src/e2e-test.ts"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "ink": "^6.8.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "eslint": "^9.22.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
